# Copy to .env and fill in values. Do NOT commit .env.
#
# Runtime queries flow through Prisma Accelerate. Generate the URL
# from the Prisma Data Platform — it looks like
#   prisma://accelerate.prisma-data.net/?api_key=...
# or, from newer Accelerate setups,
#   prisma+postgres://accelerate.prisma-data.net/?api_key=...
PRISMA_ACCELERATE_URL="prisma://accelerate.prisma-data.net/?api_key=YOUR_KEY"
# Migrations and `prisma db push` need a direct Postgres connection.
# On Railway, DATABASE_URL is set to the Accelerate URL (HTTP-only —
# cannot run migrations), so migrations read a separate DIRECT_URL
# pointing at the real Postgres. Set this in Railway to
# ${{Postgres.DATABASE_URL}}. Locally, point it at your dev DB.
DIRECT_URL="postgresql://user:password@localhost:5432/untilthen?schema=public"
# DATABASE_URL is used by a couple of guard checks and is provisioned
# automatically on Railway. In production it will equal the Accelerate
# URL; locally, you can mirror it with the same direct Postgres URL.
DATABASE_URL="postgresql://user:password@localhost:5432/untilthen?schema=public"

# Clerk auth (parent accounts). Both are required for /sign-in,
# /sign-up, /onboarding, /dashboard to work.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# Resend (transactional emails: invites, reveal-day, etc.).
# Without this set, email sends are silently skipped.
RESEND_API_KEY=""

# Cron job secret. Railway cron sends this as a Bearer token
# to authenticate /api/cron/* endpoints. Generate any random
# string (e.g. openssl rand -hex 32).
CRON_SECRET=""

# PostHog analytics (client-side). Without NEXT_PUBLIC_POSTHOG_KEY set,
# capture calls no-op and the provider initialises nothing.
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# Admin dashboard password. Required for /admin to load.
ADMIN_PASSWORD=""

# Cloudflare R2 (media storage: photos / voice notes / videos).
# Without these set, the editor hides media attachments and any
# attempt to upload returns 503.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="untilthen-media"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Sentry error monitoring. Both vars hold the same DSN — the
# NEXT_PUBLIC_ one is needed for the browser bundle. Without
# them set, Sentry initialises but only when NODE_ENV=production
# (the configs gate on this), so dev runs stay quiet.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
# Optional — when set, the Sentry webpack plugin uploads source
# maps so server stack traces are readable. Generate from the
# Sentry org's Auth Tokens page.
SENTRY_AUTH_TOKEN=""

# Upstash Redis — backs IP-keyed rate limits in middleware.
# When unset, middleware falls back to a no-op (every request
# passes), so dev and preview deploys aren't broken by missing
# Redis. Production MUST set both for the limits to bite.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
