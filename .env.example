# Copy to .env and fill in values. Do NOT commit .env.
#
# Direct Postgres connection string. On Railway, set to
# ${{Postgres.DATABASE_URL}}. Locally, point at your dev DB.
DATABASE_URL="postgresql://user:password@localhost:5432/untilthen?schema=public"

# Clerk auth (parent accounts). Both are required for /sign-in,
# /sign-up, /onboarding, /dashboard to work.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# Resend (transactional emails: invites, reveal-day, etc.).
# Without this set, email sends are silently skipped.
RESEND_API_KEY=""

# Cron job secret. Railway cron sends this as a Bearer token
# to authenticate /api/cron/* endpoints. Generate any random
# string (e.g. openssl rand -hex 32).
CRON_SECRET=""

# PostHog analytics (client-side). Without NEXT_PUBLIC_POSTHOG_KEY set,
# capture calls no-op and the provider initialises nothing.
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# Admin dashboard password. Required for /admin to load.
ADMIN_PASSWORD=""

# Cloudflare R2 (media storage: photos / voice notes / videos).
# Without these set, the editor hides media attachments and any
# attempt to upload returns 503.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="untilthen-media"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Sentry error monitoring. Both vars hold the same DSN — the
# NEXT_PUBLIC_ one is needed for the browser bundle. Without
# them set, Sentry initialises but only when NODE_ENV=production
# (the configs gate on this), so dev runs stay quiet.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
# Optional — when set, the Sentry webpack plugin uploads source
# maps so server stack traces are readable. Generate from the
# Sentry org's Auth Tokens page.
SENTRY_AUTH_TOKEN=""

# Upstash Redis — backs IP-keyed rate limits in middleware.
# When unset, middleware falls back to a no-op (every request
# passes), so dev and preview deploys aren't broken by missing
# Redis. Production MUST set both for the limits to bite.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Square payments. Production tokens only — Sandbox is never
# used in a deployed build. When any of the required vars are
# missing, /api/capsules/[id]/activate and the subscribe /
# add-on routes short-circuit to 503 so the UI can surface a
# clean 'payments unavailable' message instead of leaking a
# stack trace.
#
# Required:
SQUARE_APPLICATION_ID=""
SQUARE_ACCESS_TOKEN=""
SQUARE_LOCATION_ID=""
# Client-side (exposed to the browser):
NEXT_PUBLIC_SQUARE_APPLICATION_ID=""
NEXT_PUBLIC_SQUARE_LOCATION_ID=""
# Webhook signature key — set after creating the webhook
# subscription in the Square Developer Dashboard. Without it
# POST /api/webhooks/square rejects every event with 401.
SQUARE_WEBHOOK_SIGNATURE_KEY=""
SQUARE_WEBHOOK_URL="https://untilthenapp.io/api/webhooks/square"
# Optional plan-id overrides — by default lib/square.ts uses
# the production plan ids hardcoded from the April 22 brief.
# Set these only in staging / sandbox environments.
# SQUARE_PLAN_MONTHLY_BASE=""
# SQUARE_PLAN_ANNUAL_BASE=""
# SQUARE_PLAN_MONTHLY_ADDON=""
# SQUARE_PLAN_ANNUAL_ADDON=""

# Reveal-experience background music. Hot-linkable MP3 URL.
# Plays at volume 0.25 on loop through the guided reveal
# sequence, muted by the same switch that mutes voice cards.
# When unset, the reveal runs silent and the music-toggle UI in
# the gallery stays hidden. Recommended: 2–4 min soft-strings
# ambient track with a seamless loop point.
#
# Suggested sources:
#   - Pixabay Music (royalty-free): https://pixabay.com/music/search/soft%20strings/
#     → hot-link the direct mp3 URL, e.g.
#       https://cdn.pixabay.com/download/audio/2023/.../soft-strings.mp3
#   - Drop an MP3 into /public and set to /reveal-music.mp3
#   - Upload to the R2 bucket and set to the public CDN URL
NEXT_PUBLIC_REVEAL_MUSIC_URL=""
