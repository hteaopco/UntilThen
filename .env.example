# Copy to .env and fill in values. Do NOT commit .env.
# Railway will inject DATABASE_URL automatically when you attach Postgres.
DATABASE_URL="postgresql://user:password@localhost:5432/untilthen?schema=public"

# Clerk auth (parent accounts). Both are required for /sign-in,
# /sign-up, /onboarding, /dashboard to work.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# Resend (waitlist confirmation emails). Without this set, the
# /api/waitlist endpoint still accepts submissions but skips the email.
RESEND_API_KEY=""

# PostHog analytics (client-side). Without NEXT_PUBLIC_POSTHOG_KEY set,
# capture calls no-op and the provider initialises nothing.
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# Admin dashboard password. Required for /admin to load.
ADMIN_PASSWORD=""

# Cloudflare R2 (media storage: photos / voice notes / videos).
# Without these set, the editor hides media attachments and any
# attempt to upload returns 503.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="untilthen-media"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
