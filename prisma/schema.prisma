// Prisma schema for untilThen

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Waitlist ───────────────────────────────────────────────

model Waitlist {
  id          String    @id @default(cuid())
  email       String    @unique
  firstName   String
  lastName    String
  phone       String?
  dateOfBirth DateTime?
  numChildren Int
  hearAboutUs String?
  createdAt   DateTime  @default(now())
  ipAddress   String?
}

// ── Auth + vaults ──────────────────────────────────────────

enum Role {
  PARENT
  CHILD
  CONTRIBUTOR
}

enum EntryType {
  TEXT
  PHOTO
  VOICE
  VIDEO
}

enum ApprovalStatus {
  PENDING_REVIEW
  AUTO_APPROVED
  APPROVED
  REJECTED
}

enum ContributorRole {
  FAMILY
  FRIEND
  TEACHER
  OTHER
}

enum ContributorStatus {
  PENDING
  ACTIVE
  REVOKED
}

model User {
  id          String   @id @default(cuid())
  clerkId     String   @unique
  firstName   String
  lastName    String
  displayName String?
  role        Role     @default(PARENT)
  createdAt   DateTime @default(now())

  children                Child[]
  entries                 Entry[]
  collections             Collection[]
  notificationPreferences NotificationPreferences?
}

model Child {
  id           String    @id @default(cuid())
  firstName    String
  lastName     String
  dateOfBirth  DateTime?
  parentId     String
  trusteeName  String?
  trusteeEmail String?
  createdAt    DateTime  @default(now())

  parent User   @relation(fields: [parentId], references: [id])
  vault  Vault?
}

model Vault {
  id         String    @id @default(cuid())
  childId    String    @unique
  revealDate DateTime?
  unlockedAt DateTime?
  createdAt  DateTime  @default(now())

  child        Child         @relation(fields: [childId], references: [id])
  entries      Entry[]
  collections  Collection[]
  contributors Contributor[]
}

model Collection {
  id          String    @id @default(cuid())
  vaultId     String
  authorId    String
  title       String
  description String?
  coverEmoji  String?
  revealDate  DateTime?
  isSealed    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  unlockedAt  DateTime?

  vault   Vault   @relation(fields: [vaultId], references: [id])
  author  User    @relation(fields: [authorId], references: [id])
  entries Entry[]

  @@index([vaultId])
}

model Contributor {
  id               String            @id @default(cuid())
  vaultId          String
  invitedBy        String // parent's Clerk user id
  email            String
  name             String?
  role             ContributorRole   @default(FAMILY)
  status           ContributorStatus @default(PENDING)
  requiresApproval Boolean           @default(false)
  inviteToken      String            @unique @default(cuid())
  clerkUserId      String?
  createdAt        DateTime          @default(now())
  acceptedAt       DateTime?

  vault   Vault   @relation(fields: [vaultId], references: [id])
  entries Entry[]

  @@index([vaultId])
  @@index([inviteToken])
  @@index([clerkUserId])
}

model Entry {
  id             String         @id @default(cuid())
  vaultId        String
  authorId       String
  contributorId  String?
  collectionId   String?
  orderIndex     Int?
  type           EntryType      @default(TEXT)
  title          String?
  body           String? // Tiptap HTML
  mediaUrls      String[]       @default([]) // R2 keys
  mediaTypes     String[]       @default([]) // matching "photo" | "voice" | "video"
  tag            String?
  revealDate     DateTime?
  isDraft        Boolean        @default(true)
  isSealed       Boolean        @default(false)
  isPrivate      Boolean        @default(false)
  approvalStatus ApprovalStatus @default(AUTO_APPROVED)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt @default(now())
  unlockedAt     DateTime?

  vault       Vault        @relation(fields: [vaultId], references: [id])
  author      User         @relation(fields: [authorId], references: [id])
  contributor Contributor? @relation(fields: [contributorId], references: [id])
  collection  Collection?  @relation(fields: [collectionId], references: [id])

  @@index([collectionId])
  @@index([contributorId])
  @@index([approvalStatus])
  @@index([vaultId, isSealed])
}

model NotificationPreferences {
  id                  String    @id @default(cuid())
  userId              String    @unique
  writingReminders    Boolean   @default(true)
  milestoneReminders  Boolean   @default(true)
  vaultAnniversary    Boolean   @default(true)
  contributorActivity Boolean   @default(true)
  revealCountdown     Boolean   @default(true)
  pausedUntil         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])
}
