// Prisma schema for untilThen

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Waitlist ───────────────────────────────────────────────

model Waitlist {
  id          String    @id @default(cuid())
  email       String    @unique
  firstName   String
  lastName    String
  phone       String?
  dateOfBirth DateTime?
  numChildren Int
  hearAboutUs String?
  createdAt   DateTime  @default(now())
  ipAddress   String?
}

// ── Auth + vaults ──────────────────────────────────────────

enum Role {
  PARENT
  CHILD
}

enum EntryType {
  TEXT
  PHOTO
  VOICE
  VIDEO
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  firstName String
  lastName  String
  role      Role     @default(PARENT)
  createdAt DateTime @default(now())

  children    Child[]
  entries     Entry[]
  collections Collection[]
}

model Child {
  id          String    @id @default(cuid())
  firstName   String
  lastName    String
  dateOfBirth DateTime?
  parentId    String
  createdAt   DateTime  @default(now())

  parent User   @relation(fields: [parentId], references: [id])
  vault  Vault?
}

model Vault {
  id         String    @id @default(cuid())
  childId    String    @unique
  revealDate DateTime?
  unlockedAt DateTime?
  createdAt  DateTime  @default(now())

  child       Child        @relation(fields: [childId], references: [id])
  entries     Entry[]
  collections Collection[]
}

model Collection {
  id          String    @id @default(cuid())
  vaultId     String
  authorId    String
  title       String
  description String?
  coverEmoji  String?
  revealDate  DateTime?
  isSealed    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  unlockedAt  DateTime?

  vault   Vault   @relation(fields: [vaultId], references: [id])
  author  User    @relation(fields: [authorId], references: [id])
  entries Entry[]

  @@index([vaultId])
}

model Entry {
  id           String      @id @default(cuid())
  vaultId      String
  authorId     String
  collectionId String?
  orderIndex   Int?
  type         EntryType   @default(TEXT)
  title        String?
  body         String?
  mediaUrl     String?
  tag          String?
  revealDate   DateTime?
  isPrivate    Boolean     @default(false)
  createdAt    DateTime    @default(now())
  unlockedAt   DateTime?

  vault      Vault       @relation(fields: [vaultId], references: [id])
  author     User        @relation(fields: [authorId], references: [id])
  collection Collection? @relation(fields: [collectionId], references: [id])

  @@index([collectionId])
}
