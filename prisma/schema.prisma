// Prisma schema for untilThen

generator client {
  provider      = "prisma-client-js"
  engineType    = "library"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Auth + vaults ──────────────────────────────────────────

enum Role {
  PARENT
  CHILD
  CONTRIBUTOR
}

enum EntryType {
  TEXT
  PHOTO
  VOICE
  VIDEO
}

enum ApprovalStatus {
  PENDING_REVIEW
  AUTO_APPROVED
  APPROVED
  REJECTED
}

// Hive content moderation outcome per contribution.
//
// NOT_SCANNED → hasn't been submitted to Hive yet (legacy rows,
//   organiser self-contributions, or Hive not configured).
// SCANNING → Hive scan kicked off async; result not back yet.
//   Hidden from organiser + reveal views until it resolves. The
//   /api/cron/moderation-cleanup cron reclaims any row stuck in
//   this state (e.g. server crashed mid-scan) after 5 minutes.
// PASS → Hive ran and every category stayed under threshold.
// FLAGGED → At least one of { sexual, violence, hate, drugs } came
//   back over the confidence threshold. Hidden from organiser,
//   routed to /admin/moderation for a human decision.
// FAILED_OPEN → Hive API call errored, timed out, or is not
//   configured. We do NOT block the submission when the
//   moderation service is down — the contribution flows through
//   as if no moderation ran. Sentry records every failure.
enum ModerationState {
  NOT_SCANNED
  SCANNING
  PASS
  FLAGGED
  FAILED_OPEN
}

enum ContributorStatus {
  /// Added to the list but the invite email hasn't been sent
  /// yet. Used for DRAFT capsule invites that pay-to-activate.
  STAGED
  PENDING
  ACTIVE
  REVOKED
}

/// Which product a user first came through. Lets us personalise
/// the dashboard empty states and segment analytics without
/// changing the role-based access model.
///
/// - PARENT    — signed up to write to a child (child vault path)
/// - ORGANISER — signed up to run a Gift Capsule
/// - BOTH      — has created both a vault and a capsule
enum UserType {
  PARENT
  ORGANISER
  BOTH
}

model User {
  id          String   @id @default(cuid())
  clerkId     String   @unique
  firstName   String
  lastName    String
  displayName String?
  avatarUrl   String?
  /// Email address mirrored from Clerk so we can match
  /// CapsuleInvite.email + CapsuleContribution.authorEmail
  /// back to the User row (e.g. for showing real avatars on
  /// the gift-capsule dashboard cards). New users get this
  /// written by /api/onboarding at create time; existing rows
  /// backfill on next sign-in via the helper in src/lib/user-sync.ts.
  email       String?  @unique
  /// Optional phone number for the user. Not collected in the UI
  /// today — column added ahead of time so future SMS / 2FA
  /// features can write to it without a new migration.
  phone       String?
  // Vault PIN is opt-in. When pinHash is null the PIN gate is
  // disabled (default). When set, the user must enter the 4-digit
  // PIN once per session to access /dashboard and /vault. Reset
  // via email — a one-time token is hashed and stored in
  // pinResetTokenHash with a short TTL in pinResetExpires.
  pinHash              String?
  pinResetTokenHash    String?
  pinResetExpires      DateTime?
  role        Role     @default(PARENT)
  userType    UserType @default(PARENT)
  createdAt   DateTime @default(now())

  // Payment access flags. When either is true, the matching
  // paywall gate short-circuits to 'allowed' — used for
  // employees, comped early testers, and anyone given permanent
  // free access via the admin Users table. Defaults to false so
  // the standard subscription gate applies.
  freeVaultAccess Boolean @default(false)
  freeGiftAccess  Boolean @default(false)
  // Square Customer resource id, set once the user's card is
  // saved on file during a SubscriptionCheckout flow. Null for
  // users who have never completed a paid checkout.
  squareCustomerId String?
  // Current card on file, shared across the base subscription
  // and every addon. Updating the card means replacing this row
  // AND calling subscriptions.update on every sub so they all
  // point at the new card — enforced atomically in the
  // /api/payments/update-card endpoint (rolls back on partial
  // failure). squareCardBrand + last4 power the billing-page
  // "Visa •••• 4242" summary.
  squareCardId     String?
  squareCardBrand  String?
  squareCardLast4  String?

  children                Child[]
  entries                 Entry[]
  collections             Collection[]
  memoryCapsules          MemoryCapsule[]
  notificationPreferences NotificationPreferences?
  subscription            Subscription?
  organizationMemberships OrganizationMember[]
  organizationUpdates     OrganizationUpdate[]
}

model Child {
  id           String    @id @default(cuid())
  firstName    String
  lastName     String
  dateOfBirth  DateTime?
  parentId     String
  trusteeName  String?
  trusteeEmail String?
  trusteePhone String?
  // What this child calls the parent — "Dad", "Mom", "Mama",
  // "Papa", "Jett", etc. Falls back to User.displayName /
  // firstName when null. Per-capsule because the same parent
  // wants different labels per child (e.g. "Dad" to one kid,
  // first name to another).
  parentDisplayName String?
  createdAt    DateTime  @default(now())

  parent User   @relation(fields: [parentId], references: [id])
  vault  Vault?
}

model Vault {
  id           String    @id @default(cuid())
  childId      String    @unique
  coverUrl     String?
  revealDate   DateTime?
  deliveryTime String    @default("08:00")
  timezone     String    @default("America/Chicago")
  unlockedAt   DateTime?
  // Paywall lock state. A locked vault is read-only: entries
  // stay visible but no new memories can be added and no media
  // uploaded. Set when a user's active slot count drops below
  // their capsule count (e.g. after an addon is removed) and
  // toggleable manually from the capsules page.
  isLocked     Boolean   @default(false)
  lockedAt     DateTime?
  // Timestamp of the most recent MANUAL lock/unlock toggle from
  // the capsules page. Auto-locks triggered by addon removal or
  // subscription expiry leave this unchanged. Gate: a user can
  // only manually flip lock state once every 90 days to prevent
  // rotating capsules against a single paid slot.
  lastLockToggleAt DateTime?
  // Reveal-reel curation. RANDOM lets RevealExperience pick the
  // first 5 modality slides; BUILD plays curatedSlides exactly.
  // curatedSlides is an array of {entryId, view} objects, where
  // view ∈ "letter" | "VOICE" | "PHOTO" | "VIDEO" — written by
  // the curator UI on the capsule landing page.
  revealMode       RevealMode  @default(RANDOM)
  curatedSlides    Json?
  revealSongId     String?
  revealSong       RevealSong? @relation(fields: [revealSongId], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now())

  child       Child        @relation(fields: [childId], references: [id])
  entries     Entry[]
  collections Collection[]

  @@index([revealDate])
  @@index([revealSongId])
}

enum RevealMode {
  /// Auto-pick first 5 chronological modality slides (legacy default).
  RANDOM
  /// Use curatedSlides exactly.
  BUILD
}

/// Reveal background music — admin-uploaded MP3s that capsule
/// owners pick from on their capsule landing. Stored in R2
/// under a "reveal-music/" prefix; signed on demand for the
/// reveal player.
model RevealSong {
  id           String   @id @default(cuid())
  name         String
  r2Key        String   @unique
  /// Optional duration in seconds for UI badges; null when we
  /// don't have it yet.
  durationSec  Int?
  uploadedAt   DateTime @default(now())

  vaults Vault[]
}

model Collection {
  id          String    @id @default(cuid())
  vaultId     String
  authorId    String
  title       String
  description String?
  coverEmoji  String?
  coverUrl    String?
  revealDate  DateTime?
  isSealed    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  unlockedAt  DateTime?

  vault   Vault   @relation(fields: [vaultId], references: [id])
  author  User    @relation(fields: [authorId], references: [id])
  entries Entry[]

  @@index([vaultId])
}

model Entry {
  id             String         @id @default(cuid())
  vaultId        String
  authorId       String
  collectionId   String?
  orderIndex     Int?
  type           EntryType      @default(TEXT)
  title          String?
  body           String? // Tiptap HTML
  mediaUrls      String[]       @default([]) // R2 keys
  mediaTypes     String[]       @default([]) // matching "photo" | "voice" | "video"
  tag            String?
  revealDate     DateTime?
  isDraft        Boolean        @default(true)
  isSealed       Boolean        @default(false)
  isPrivate      Boolean        @default(false)
  approvalStatus ApprovalStatus @default(AUTO_APPROVED)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt @default(now())
  unlockedAt     DateTime?

  // Hive content moderation — same pipeline as CapsuleContribution.
  // The parent writing in their own vault runs through Hive too so
  // abusive content can't be stashed under the "memories" surface.
  // Entries start NOT_SCANNED (for backfill safety); new writes
  // flip to SCANNING immediately on create/edit and the cron
  // reclaims stuck ones to FAILED_OPEN after 5 minutes.
  moderationState ModerationState @default(NOT_SCANNED)
  moderationFlags Json?
  moderationRunAt DateTime?

  vault      Vault       @relation(fields: [vaultId], references: [id])
  author     User        @relation(fields: [authorId], references: [id])
  collection Collection? @relation(fields: [collectionId], references: [id])

  @@index([collectionId])
  @@index([approvalStatus])
  @@index([vaultId, isSealed])
  @@index([authorId, createdAt])
  @@index([moderationState])
}

// ── Gift Capsules ───────────────────────────────────────
//
// Second product type: a one-time, occasion-based capsule
// (birthday, anniversary, retirement, etc.). Separate from the
// child Vault so its lifecycle, pricing model, and recipient
// flow can evolve independently — contributions are public-
// facing (no Clerk account required) and the recipient opens
// via a magic link.

enum OccasionType {
  BIRTHDAY
  ANNIVERSARY
  RETIREMENT
  GRADUATION
  WEDDING
  JUST_BECAUSE
  ENGAGEMENT
  BAPTISM
  CONGRATULATIONS
  THANK_YOU
  FRIENDSHIP
  GET_WELL
  SYMPATHY
  OTHER
}

enum CapsuleTone {
  CELEBRATION
  GRATITUDE
  THINKING_OF_YOU
  ENCOURAGEMENT
  LOVE
  OTHER
}

enum CapsuleStatus {
  DRAFT // Created, not paid, no invites sent yet.
  ACTIVE // Paid, collecting contributions.
  SEALED // Past contributor deadline.
  REVEALED // Recipient has opened it.
}

model MemoryCapsule {
  id                  String        @id @default(cuid())
  /// Nullable on purpose: when the organiser deletes their account,
  /// capsules that are SENT/REVEALED or already saved by the
  /// recipient are kept so the recipient never loses access.
  /// organiserId is set to null on those rows; everything else
  /// (DRAFT/ACTIVE with no recipient save) is hard-deleted with
  /// the user.
  organiserId         String?
  title               String
  recipientName       String
  /// Object-form pronoun for this recipient ("her" / "him" /
  /// "them"). Used in emotional copy where the recipient name
  /// would read too rigidly. Null = default to "them".
  recipientPronoun    String?
  /// Both contact fields are optional at creation time. Activation
  /// (the paywall) collects at least one before flipping the
  /// capsule to ACTIVE — enforced server-side in /activate.
  recipientEmail      String?
  /// Second recipient email for couple gift capsules. The reveal
  /// cron loops over [recipientEmail, recipient2Email,
  /// ...additionalRecipients] and sends to each non-null entry;
  /// single-recipient capsules leave this null. Kept for
  /// back-compat with capsules created before the N-recipient
  /// flow shipped — new capsules with 2+ people store everyone
  /// past the primary in `additionalRecipients`.
  recipient2Email     String?
  /// Recipients past the primary one. Json array of
  /// `{ firstName: string; lastName: string; email: string }`,
  /// in display order. The primary recipient's first/last is
  /// baked into recipientName + recipientEmail; this column
  /// captures everyone after that without needing a join table
  /// or per-recipient row migration. Null for single-recipient
  /// (or pre-multi-recipient) capsules.
  additionalRecipients Json?
  recipientPhone      String?
  occasionType        OccasionType  @default(OTHER)
  tone                CapsuleTone   @default(CELEBRATION)
  revealDate          DateTime
  contributorDeadline DateTime?
  status              CapsuleStatus @default(DRAFT)
  /// Manual seal — when true, /invites + /contribute submit
  /// routes return 410 ("contributions closed") and the
  /// dashboard pill reads SEALED even on an ACTIVE capsule.
  /// Reversible by the organiser; reveal cron is unaffected.
  /// Treated as effectively-SEALED via lib/capsules.ts
  /// effectiveStatus().
  contributionsClosed Boolean       @default(false)
  requiresApproval    Boolean       @default(false)
  // paymentId holds the Square Payment resource id once the
  // organiser's $9.99 one-time charge clears. Historic DRAFT
  // rows with a placeholder value will remain until that data
  // cycles out; new activations always write a real Square id.
  paymentId           String?
  isPaid              Boolean       @default(false)
  // Timestamp of when isPaid flipped to true. Null for
  // unactivated capsules; pinned on the payment webhook /
  // activation transaction so refund/reversal flows can tell
  // which charge to reverse.
  paidAt              DateTime?
  accessToken         String        @unique @default(cuid())
  tokenExpiresAt      DateTime?
  /// Open contribution token for WEDDING capsules — printed on
  /// the easel/table cards as a QR code so guests can scan and
  /// leave a memory without a per-guest invite. Generated only
  /// when occasionType = WEDDING; null for every other occasion.
  /// Distinct from accessToken (recipient's reveal magic link)
  /// so leaking the QR doesn't leak the reveal.
  guestToken          String?       @unique
  recipientClerkId    String?
  deliveryTime        String        @default("09:00")
  timezone            String        @default("America/Chicago")
  firstOpenedAt       DateTime?
  recipientCompletedAt DateTime?
  /// Optional org attribution. Set when a capsule is created
  /// by a user who's a member of an Organization (loss-leader
  /// enterprise channel) — drives org usage reporting + the
  /// transfer flow on offboarding. Null for personal capsules.
  organizationId      String?
  /// Optional cover image — square photo the organiser uploads
  /// to give the capsule a face. R2 object key (the same shape
  /// as Vault.coverUrl / Collection.coverUrl); render via a
  /// signed GET URL. Null = use the gradient + initials
  /// placeholder.
  coverUrl            String?
  /// Optional free-text note from the organiser to every
  /// contributor — shown on the contributor invite phase as
  /// quoted, signed copy. Soft-capped at 500 chars on the API
  /// + the inline editor; null = invite phase shows only the
  /// templated tone copy. Editable until the capsule is sealed.
  organiserNote       String?
  /// Wedding-specific: when the bride/groom buys the capsule
  /// themselves but doesn't want to read messages early. With
  /// this true, the organiser's own dashboard redacts every
  /// contribution body until revealDate — only the count is
  /// visible. Reverts automatically once revealDate passes;
  /// guests / contributions list /api routes are unaffected.
  hideUntilReveal     Boolean       @default(false)
  /// Soft hide for the organiser's dashboard. Once a capsule has
  /// been SENT or REVEALED, hard delete is blocked so the
  /// recipient never loses access — but the organiser can still
  /// move the row out of their main view via archive. Null means
  /// not archived; a timestamp records when it was archived for
  /// audit purposes.
  archivedAt          DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  organiser     User?                 @relation(fields: [organiserId], references: [id], onDelete: SetNull)
  organization  Organization?         @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  contributions CapsuleContribution[]
  invites       CapsuleInvite[]
  transfers     CapsuleTransfer[]
  saveForLaters WeddingSaveForLater[]

  @@index([organiserId])
  @@index([accessToken])
  @@index([status])
  @@index([organizationId])
}

// ── Capsule transfer (bride/groom hand-off) ───────────────
//
// Wedding flow: the bride/groom buys the capsule but wants
// someone else (planner, MOH, parent) to manage it through
// reveal day so they don't accidentally see messages early.
// This row tracks the pending hand-off; the recipient clicks
// the magic link, signs in (or signs up) with the matching
// email, and on accept we flip MemoryCapsule.organiserId.
//
// Once accepted, the original purchaser still has a row in
// the contributions table (their "From" message) but is no
// longer the organiser, so /capsules/[id] redirects them.

enum CapsuleTransferStatus {
  PENDING
  ACCEPTED
  CANCELED
}

// ── Wedding "Save For Later" leads ────────────────────────
//
// Captured from the guest contributor flow when a guest taps
// "Save For Later" on the invitation card. We store first/last
// + phone with the originating guestToken so an SMS reminder
// (Twilio integration TBD) can later fire a one-tap link back
// to the same /wedding/[token] URL.
//
// One row per submission — no dedup on (capsuleId, phone)
// because a guest may opt in twice and we'd rather over-remind
// than silently swallow.
model WeddingSaveForLater {
  id          String   @id @default(cuid())
  capsuleId   String
  guestToken  String
  firstName   String
  lastName    String
  phone       String
  /// True once the SMS reminder has fired. Stays false until
  /// we wire Twilio; the cron that eventually dispatches will
  /// flip this in the same write that records the message id.
  reminderSent Boolean @default(false)
  reminderSentAt DateTime?
  createdAt   DateTime @default(now())

  capsule MemoryCapsule @relation(fields: [capsuleId], references: [id], onDelete: Cascade)

  @@index([capsuleId])
  @@index([guestToken])
  @@index([reminderSent])
  @@index([createdAt])
}

model CapsuleTransfer {
  id          String                @id @default(cuid())
  capsuleId   String
  /// User.id of the person initiating the transfer (current
  /// organiser at request time). Held even after accept so we
  /// can audit who handed off to whom.
  fromUserId  String
  toEmail     String
  toFirstName String
  toLastName  String
  toPhone     String?
  /// Magic-link token. Single-use, swapped for an organiserId
  /// flip on accept.
  token       String                @unique @default(cuid())
  status      CapsuleTransferStatus @default(PENDING)
  invitedAt   DateTime              @default(now())
  acceptedAt  DateTime?
  /// User.id of the accepting user once the magic link is
  /// followed. Same value gets written to MemoryCapsule.organiserId
  /// in the same transaction.
  acceptedUserId String?

  capsule MemoryCapsule @relation(fields: [capsuleId], references: [id], onDelete: Cascade)

  @@index([capsuleId])
  @@index([toEmail])
  @@index([status])
}

model CapsuleContribution {
  id             String         @id @default(cuid())
  capsuleId      String
  authorName     String
  authorEmail    String?
  /// Set when the contribution comes from the organiser's own
  /// "Your contribution" editor. Lets the organiser edit or
  /// delete their own post-creation without needing a token.
  /// Null for public-facing contributions (contributor invites).
  clerkUserId    String?
  /// Per-contribution opaque token granting edit access via
  /// /wedding/<guestToken>?edit=<editToken>. Wedding guests who
  /// opt to "save my email so I can edit later" receive this in
  /// the editable-card email. Stays null for non-wedding rows
  /// and for guests who skipped the email prompt. Editable while
  /// the capsule is ACTIVE; once SEALED, the link returns a
  /// "too late" screen.
  editToken      String?        @unique
  type           EntryType      @default(TEXT)
  title          String?
  body           String?
  mediaUrls      String[]       @default([])
  mediaTypes     String[]       @default([])
  approvalStatus ApprovalStatus @default(AUTO_APPROVED)
  orderIndex     Int?
  createdAt      DateTime       @default(now())

  // Hive content moderation result. `moderationFlags` carries the
  // per-category confidence scores we observed (e.g. `{"sexual":
  // 0.91, "violence": 0.12}`), so the admin UI can show exactly
  // what triggered the flag.
  moderationState ModerationState @default(NOT_SCANNED)
  moderationFlags Json?
  moderationRunAt DateTime?

  capsule MemoryCapsule @relation(fields: [capsuleId], references: [id], onDelete: Cascade)

  @@index([capsuleId])
  @@index([clerkUserId])
  @@index([approvalStatus])
  @@index([moderationState])
}

model CapsuleInvite {
  id               String            @id @default(cuid())
  capsuleId        String
  email            String
  name             String?
  inviteToken      String            @unique @default(cuid())
  status           ContributorStatus @default(PENDING)
  /// Per-contributor approval toggle. When true, this
  /// contributor's submission lands as PENDING_REVIEW and the
  /// organiser reviews it before the recipient sees it on
  /// reveal day. Backfilled from the old capsule-level flag.
  requiresApproval Boolean           @default(false)
  createdAt        DateTime          @default(now())
  acceptedAt       DateTime?

  capsule MemoryCapsule @relation(fields: [capsuleId], references: [id], onDelete: Cascade)

  @@index([capsuleId])
  @@index([inviteToken])
}

model NotificationPreferences {
  id                  String    @id @default(cuid())
  userId              String    @unique
  writingReminders    Boolean   @default(true)
  milestoneReminders  Boolean   @default(true)
  vaultAnniversary    Boolean   @default(true)
  revealCountdown     Boolean   @default(true)
  pausedUntil         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])
}

// ── Payments ────────────────────────────────────────────────
// See docs plan / `lib/paywall.ts` for how these gate vault
// creation + gift-capsule activation. Both models stay opt-in
// — they only come into play once AppConfig.paywallEnabled is
// flipped to true.

enum SubscriptionPlan {
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  LOCKED
}

model Subscription {
  id                String             @id @default(cuid())
  userId            String             @unique
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Square's Subscription resource id. Unique so webhook
  // lookups by Square id can hit the index directly.
  squareSubId       String             @unique
  plan              SubscriptionPlan
  status            SubscriptionStatus @default(ACTIVE)
  // 3 base capsule slots are included in the standard plan;
  // every additional capsule past that is an add-on that bumps
  // addonCapsuleCount up by one at $0.99/mo or $6/yr.
  baseCapsuleCount  Int                @default(3)
  addonCapsuleCount Int                @default(0)
  // Square subscription ids for each $0.99/$6 addon. One entry
  // per active addon. Lets us cancel a specific addon (pop one
  // off and call Square cancel) without needing a per-capsule
  // linkage — capsules and slots are decoupled.
  addonSquareSubIds String[]           @default([])
  // End of the current billing period. Set at every renewal so
  // CANCELLED subscriptions can stay 'active enough' until the
  // paid period lapses.
  currentPeriodEnd  DateTime
  // Scheduled plan switch. When the user upgrades monthly → annual
  // or downgrades annual → monthly, the swap takes effect at the
  // end of the current billing period. The new Square subscription
  // is created immediately with a delayed start_date; these fields
  // hold its details until the old sub expires and the webhook
  // promotes them into `plan` + `squareSubId`.
  pendingPlan          SubscriptionPlan?
  pendingSquareSubId   String?           @unique
  pendingEffectiveDate DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

// Single-row config table. The id column is locked to the
// string "singleton" via the default so every read / write
// hits the same row — no other rows are ever created.
// Seeded with paywallEnabled: false in the migration so
// pre-launch testing doesn't immediately start demanding
// payment.
model AppConfig {
  id             String   @id @default("singleton")
  paywallEnabled Boolean  @default(false)
  // Kill switch for the 90-day manual-lock-toggle cooldown.
  // When true, /api/account/vaults/[id]/lock ignores
  // lastLockToggleAt and lets users rotate capsules freely.
  // Used during pre-launch testing to move state around without
  // burning the cooldown.
  lockThrottleDisabled Boolean @default(false)
  updatedAt      DateTime @updatedAt
}

// ── Cron health monitoring ────────────────────────────────

enum CronStatus {
  RUNNING
  OK
  ERROR
}

// One row per cron execution. Written via withCronRun() in
// src/lib/cron-run.ts. Powers the "Cron health" card on /admin
// and the alert-when-stale flow in /api/cron/cron-health-check.
model CronRun {
  id           String     @id @default(cuid())
  cronName     String
  startedAt    DateTime   @default(now())
  finishedAt   DateTime?
  status       CronStatus @default(RUNNING)
  durationMs   Int?
  errorMessage String?
  metadata     Json?

  @@index([cronName, startedAt])
  @@index([startedAt])
}

// Tracks the last time we emailed an alert for a given cron so
// a single prolonged outage doesn't spam the support inbox.
// Keyed by cron name — one row per cron at most.
model CronAlertState {
  cronName    String   @id
  lastAlertAt DateTime
}

// ── Admin audit log ────────────────────────────────────────

// Records every mutating admin action. Read-only admin views
// (GETs, list fetches) are intentionally NOT logged — the log
// is for accountability of state changes. Retention: 365 days,
// pruned by the /api/cron/prune-audit-log cron.
//
// Admin auth is a shared password cookie today, so "actor" is
// approximated by (ipAddress, userAgent). If we migrate to
// per-admin identities later, add an `adminId` column.
model AdminAuditLog {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  // Dotted namespace — "{surface}.{verb}". Examples:
  // "user.delete", "contribution.approve", "reveal-song.upload".
  action     String
  // Optional target entity — not every action has one (auth.*).
  targetType String?
  targetId   String?
  // Per-action context (fields changed, counts, email addresses
  // redacted, etc.). Keep small — this table is append-only.
  metadata   Json?
  ipAddress  String?
  userAgent  String?

  @@index([createdAt])
  @@index([action])
  @@index([targetType, targetId])
}

// ── Enterprise organizations ──────────────────────────────
//
// Loss-leader B2B channel: companies pay $99/yr (or $0.50/EE,
// whichever is greater) for the right to invite their employees
// as "enterprise contributors" who get untilThen for free. All
// capsules a member creates still belong to their personal
// account; the Org link on MemoryCapsule.organizationId is purely
// for usage reporting + the offboarding transfer flow.
//
// Roles:
//   OWNER  — single per org. Billing seat. Only role that can
//            transfer capsules between members. Created at org
//            provisioning time (admin endpoint).
//   ADMIN  — can edit roster (invite/revoke/promote/demote),
//            view all org-attributed capsules read-only, create
//            their own capsules.
//   MEMBER — can create capsules only. Can't see other members.

enum OrganizationRole {
  OWNER
  ADMIN
  MEMBER
}

enum OrganizationInviteStatus {
  PENDING
  ACCEPTED
  REVOKED
}

model Organization {
  id                  String   @id @default(cuid())
  name                String
  /// Internal-only contact for invoicing. Sales team manually
  /// emails this address; no automated billing in Phase 1.
  billingContactEmail String?
  /// Free-text notes for the sales/admin team (industry,
  /// renewal dates, contract terms, etc.). Never user-visible.
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  members   OrganizationMember[]
  invites   OrganizationInvite[]
  capsules  MemoryCapsule[]
  employees OrganizationEmployee[]
  updates   OrganizationUpdate[]
}

/// Free-text announcement an org OWNER/ADMIN posts that surfaces
/// on every member's /dashboard/updates page. Used for things like
/// "We've added 50 new contributor seats" or "Reminder: end-of-year
/// capsule submission deadline is Dec 15". Authored by the
/// posting admin via OrganizationMember (so deletion of the User
/// row leaves the update intact); the update keeps a copy of the
/// authorName at write time so a deleted membership doesn't blank
/// the byline.
model OrganizationUpdate {
  id             String   @id @default(cuid())
  organizationId String
  /// User id of the OWNER/ADMIN who posted the update. Nullable
  /// so an admin who later leaves the org doesn't take the post
  /// with them; we fall back to authorName on render.
  authorUserId   String?
  authorName     String
  title          String
  body           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  author       User?        @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
}

model OrganizationMember {
  id             String           @id @default(cuid())
  organizationId String
  userId         String
  role           OrganizationRole @default(MEMBER)
  joinedAt       DateTime         @default(now())
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // A user can only hold one role per org (no duplicate
  // memberships). They can belong to multiple orgs total.
  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId])
}

model OrganizationInvite {
  id             String                   @id @default(cuid())
  organizationId String
  /// Lowercased + trimmed at write time so the accept-flow
  /// lookup is case-insensitive. Matched against ALL verified
  /// emails on a User row at accept time, not just the primary,
  /// so personal-vs-work-email collisions just work.
  email          String
  /// Optional metadata captured at CSV import. Phone is stored
  /// as company metadata only — no SMS verification.
  firstName      String?
  lastName       String?
  phone          String?
  role           OrganizationRole         @default(MEMBER)
  /// Unique random token for the magic-link accept URL.
  /// Existing-user invites bypass this and auto-join, but a
  /// token is still issued in case we ever need to re-send.
  inviteToken    String                   @unique @default(cuid())
  status         OrganizationInviteStatus @default(PENDING)
  invitedAt      DateTime                 @default(now())
  acceptedAt     DateTime?
  acceptedUserId String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Prevent duplicate PENDING invites to the same email.
  // Revoked/accepted rows can co-exist with a new pending one.
  @@unique([organizationId, email])
  @@index([inviteToken])
  @@index([email])
}

// ── Email delivery tracking ───────────────────────────────
//
// Resend webhook events land here. We rely on these rows to
// surface deliverability problems (bounces, spam complaints) in
// the admin dashboard without anyone having to log into Resend.
//
// `messageId` is the Resend email id (uuid) returned at send
// time. `capsuleId` is populated when the outgoing email carried
// a `capsuleId` Resend tag — invites and ops emails leave it
// null. We don't model a foreign key to MemoryCapsule because
// the capsule may be deleted while the event log lives on.

enum EmailEventType {
  DELIVERED
  BOUNCED
  COMPLAINED
}

model EmailEvent {
  id        String         @id @default(cuid())
  messageId String
  event     EmailEventType
  recipient String
  capsuleId String?
  createdAt DateTime       @default(now())

  @@index([messageId])
  @@index([recipient])
  @@index([capsuleId])
  @@index([createdAt])
}

// ── Organization Employee Roster ───────────────────────────
//
// Lightweight people-database scoped to an org. Distinct from
// OrganizationMember (Clerk-authed users who can log in and create
// capsules) — Employees are just *records* of people the org may
// want to gift to / collect contributions from. They don't need
// untilThen accounts; the org admin maintains the list as a
// convenience datastore.
//
// Surfaced in two places:
//   - /enterprise/roster (Employees tab) — full management view
//     for OWNER + ADMIN. Sort, search, edit, bulk-edit, import.
//   - Capsule contributor / recipient pickers — read-only modal
//     filtered + grouped by department / sub team.
//
// Lifecycle (status enum):
//   ACTIVE   — currently in the org
//   ARCHIVED — admin manually removed (e.g. employee left)
//   DELETED  — removed via a CSV overwrite import
// Both inactive states are restorable; tabs at the top of the
// Employees view filter between them.

enum EmployeeStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

model OrganizationEmployee {
  id             String         @id @default(cuid())
  organizationId String
  firstName      String
  lastName       String
  /// Lowercased + trimmed at write time so duplicate detection
  /// during CSV import is case-insensitive. The unique
  /// constraint is scoped per-org so the same person can exist
  /// in multiple orgs as separate rows.
  email          String
  phone          String?
  department     String?
  subTeam        String?
  status         EmployeeStatus @default(ACTIVE)
  /// Stamped when status flips from ACTIVE → ARCHIVED/DELETED.
  /// Null while the row is ACTIVE.
  inactivatedAt  DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([organizationId, status])
  @@index([organizationId, department])
  @@index([organizationId, subTeam])
  @@index([organizationId, lastName])
}
