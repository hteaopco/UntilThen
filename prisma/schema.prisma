// Prisma schema for untilThen

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Waitlist ───────────────────────────────────────────────

model Waitlist {
  id          String    @id @default(cuid())
  email       String    @unique
  firstName   String
  lastName    String
  phone       String?
  dateOfBirth DateTime?
  numChildren Int
  hearAboutUs String?
  createdAt   DateTime  @default(now())
  ipAddress   String?
}

// ── Auth + vaults ──────────────────────────────────────────

enum Role {
  PARENT
  CHILD
  CONTRIBUTOR
}

enum EntryType {
  TEXT
  PHOTO
  VOICE
  VIDEO
}

enum ApprovalStatus {
  PENDING_REVIEW
  AUTO_APPROVED
  APPROVED
  REJECTED
}

enum ContributorRole {
  FAMILY
  FRIEND
  TEACHER
  OTHER
}

enum ContributorStatus {
  PENDING
  ACTIVE
  REVOKED
}

/// Which product a user first came through. Lets us personalise
/// the dashboard empty states and segment analytics without
/// changing the role-based access model.
///
/// - PARENT    — signed up to write to a child (child vault path)
/// - ORGANISER — signed up to run a Memory Capsule
/// - BOTH      — has created both a vault and a capsule
enum UserType {
  PARENT
  ORGANISER
  BOTH
}

model User {
  id          String   @id @default(cuid())
  clerkId     String   @unique
  firstName   String
  lastName    String
  displayName String?
  role        Role     @default(PARENT)
  userType    UserType @default(PARENT)
  createdAt   DateTime @default(now())

  children                Child[]
  entries                 Entry[]
  collections             Collection[]
  memoryCapsules          MemoryCapsule[]
  notificationPreferences NotificationPreferences?
}

model Child {
  id           String    @id @default(cuid())
  firstName    String
  lastName     String
  dateOfBirth  DateTime?
  parentId     String
  trusteeName  String?
  trusteeEmail String?
  createdAt    DateTime  @default(now())

  parent User   @relation(fields: [parentId], references: [id])
  vault  Vault?
}

model Vault {
  id         String    @id @default(cuid())
  childId    String    @unique
  revealDate DateTime?
  unlockedAt DateTime?
  createdAt  DateTime  @default(now())

  child        Child         @relation(fields: [childId], references: [id])
  entries      Entry[]
  collections  Collection[]
  contributors Contributor[]
}

model Collection {
  id          String    @id @default(cuid())
  vaultId     String
  authorId    String
  title       String
  description String?
  coverEmoji  String?
  revealDate  DateTime?
  isSealed    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  unlockedAt  DateTime?

  vault   Vault   @relation(fields: [vaultId], references: [id])
  author  User    @relation(fields: [authorId], references: [id])
  entries Entry[]

  @@index([vaultId])
}

model Contributor {
  id               String            @id @default(cuid())
  vaultId          String
  invitedBy        String // parent's Clerk user id
  email            String
  name             String?
  role             ContributorRole   @default(FAMILY)
  status           ContributorStatus @default(PENDING)
  requiresApproval Boolean           @default(false)
  inviteToken      String            @unique @default(cuid())
  clerkUserId      String?
  createdAt        DateTime          @default(now())
  acceptedAt       DateTime?

  vault   Vault   @relation(fields: [vaultId], references: [id])
  entries Entry[]

  @@index([vaultId])
  @@index([inviteToken])
  @@index([clerkUserId])
}

model Entry {
  id             String         @id @default(cuid())
  vaultId        String
  authorId       String
  contributorId  String?
  collectionId   String?
  orderIndex     Int?
  type           EntryType      @default(TEXT)
  title          String?
  body           String? // Tiptap HTML
  mediaUrls      String[]       @default([]) // R2 keys
  mediaTypes     String[]       @default([]) // matching "photo" | "voice" | "video"
  tag            String?
  revealDate     DateTime?
  isDraft        Boolean        @default(true)
  isSealed       Boolean        @default(false)
  isPrivate      Boolean        @default(false)
  approvalStatus ApprovalStatus @default(AUTO_APPROVED)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt @default(now())
  unlockedAt     DateTime?

  vault       Vault        @relation(fields: [vaultId], references: [id])
  author      User         @relation(fields: [authorId], references: [id])
  contributor Contributor? @relation(fields: [contributorId], references: [id])
  collection  Collection?  @relation(fields: [collectionId], references: [id])

  @@index([collectionId])
  @@index([contributorId])
  @@index([approvalStatus])
  @@index([vaultId, isSealed])
}

// ── Memory Capsules ───────────────────────────────────────
//
// Second product type: a one-time, occasion-based capsule
// (birthday, anniversary, retirement, etc.). Separate from the
// child Vault so its lifecycle, pricing model, and recipient
// flow can evolve independently — contributions are public-
// facing (no Clerk account required) and the recipient opens
// via a magic link.

enum OccasionType {
  BIRTHDAY
  ANNIVERSARY
  RETIREMENT
  GRADUATION
  WEDDING
  OTHER
}

enum CapsuleStatus {
  DRAFT // Created, not paid, no invites sent yet.
  ACTIVE // Paid, collecting contributions.
  SEALED // Past contributor deadline.
  REVEALED // Recipient has opened it.
}

model MemoryCapsule {
  id                  String        @id @default(cuid())
  organiserId         String
  title               String
  recipientName       String
  recipientEmail      String
  occasionType        OccasionType  @default(OTHER)
  revealDate          DateTime
  contributorDeadline DateTime?
  status              CapsuleStatus @default(DRAFT)
  requiresApproval    Boolean       @default(false)
  paymentId           String?
  isPaid              Boolean       @default(false)
  accessToken         String        @unique @default(cuid())
  tokenExpiresAt      DateTime?
  recipientClerkId    String?
  // Tracks whether the recipient has completed the first-open
  // sequential reveal. Return visits then get the browseable
  // list instead of the guided sequence.
  firstOpenedAt       DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  organiser     User                  @relation(fields: [organiserId], references: [id])
  contributions CapsuleContribution[]
  invites       CapsuleInvite[]

  @@index([organiserId])
  @@index([accessToken])
  @@index([status])
}

model CapsuleContribution {
  id             String         @id @default(cuid())
  capsuleId      String
  authorName     String
  authorEmail    String?
  type           EntryType      @default(TEXT)
  body           String?
  mediaUrls      String[]       @default([])
  mediaTypes     String[]       @default([])
  approvalStatus ApprovalStatus @default(AUTO_APPROVED)
  orderIndex     Int?
  createdAt      DateTime       @default(now())

  capsule MemoryCapsule @relation(fields: [capsuleId], references: [id], onDelete: Cascade)

  @@index([capsuleId])
}

model CapsuleInvite {
  id          String            @id @default(cuid())
  capsuleId   String
  email       String
  name        String?
  inviteToken String            @unique @default(cuid())
  status      ContributorStatus @default(PENDING)
  createdAt   DateTime          @default(now())
  acceptedAt  DateTime?

  capsule MemoryCapsule @relation(fields: [capsuleId], references: [id], onDelete: Cascade)

  @@index([capsuleId])
  @@index([inviteToken])
}

model NotificationPreferences {
  id                  String    @id @default(cuid())
  userId              String    @unique
  writingReminders    Boolean   @default(true)
  milestoneReminders  Boolean   @default(true)
  vaultAnniversary    Boolean   @default(true)
  contributorActivity Boolean   @default(true)
  revealCountdown     Boolean   @default(true)
  pausedUntil         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])
}
