// Prisma schema for UntilThen
// Phase 1: just the waitlist. Phase 2 models (User/Child/Vault/Entry)
// land when we start the app proper.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Waitlist {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  source    String?
  createdAt DateTime @default(now())
}
